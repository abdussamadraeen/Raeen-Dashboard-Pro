{
  "manifest_version": 3,
  "name": "Raeen Dashboard Pro",
  "version": "1.0.0",
  "description": "A premium, minimalist new tab dashboard with integrated AI workflows.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "topSites",
    "storage",
    "unlimitedStorage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://suggestqueries.google.com/*",
    "https://*.google.com/*",
    "https://*.gstatic.com/*",
    "https://*.googleusercontent.com/*",
    "https://*.bing.com/*",
    "https://*.live.com/*",
    "https://*.microsoftonline.com/*",
    "https://bing.biturl.top/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://www.perplexity.ai/*"
      ],
      "js": [
        "ai-inject.js"
      ]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [{
      "id": "ruleset_1",
      "enabled": true,
      "path": "rules.json"
    }]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src https://*.google.com https://*.bing.com https://*.microsoft.com;"
  }
}