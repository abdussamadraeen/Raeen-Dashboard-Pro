{
  "manifest_version": 3,
  "name": "Abdus Dashboard Pro",
  "version": "1.2.0",
  "description": "A premium, minimalist new tab dashboard with integrated AI workflows.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "topSites",
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://suggestqueries.google.com/*",
    "https://www.google.com/*",
    "https://www.bing.com/*",
    "https://*.bing.com/*",
    "https://bing.biturl.top/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://www.perplexity.ai/*"
      ],
      "js": [
        "ai-inject.js"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}